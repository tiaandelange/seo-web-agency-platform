# Copy to .env.local for development. Never commit real values.

# Absolute site origin, no trailing slash. Drives canonicals, sitemap, robots, JSON-LD URLs.
# Keep localhost for local work. Use the Vercel preview host for private previews.
# Production (only when DNS is connected and indexing is intentionally enabled):
#   NEXT_PUBLIC_SITE_URL=https://www.koppiesystems.co.za
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# "production" enables indexing (robots allow + sitemap). Anything else = staging: robots disallow all.
# Private previews must remain non-production (use "preview" or "development").
NEXT_PUBLIC_SITE_ENV=development

# Optional: GA4 measurement ID. Analytics stays disabled while unset.
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Optional: Google Search Console HTML-tag verification content value.
# Do not set on private previews.
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# --- Lead delivery (server-only) ---
# Provider: log | webhook | resend
# resend → contact/proposal use hosted Resend templates; other leads use legacy text until dedicated templates exist.
LEAD_DELIVERY_PROVIDER=log
LEAD_WEBHOOK_URL=
LEAD_WEBHOOK_SECRET=
# Optional aliases still honoured:
LEAD_DELIVERY_API_KEY=
LEAD_TO_EMAIL=
LEAD_FROM_EMAIL=

# Force local no-send even when LEAD_DELIVERY_PROVIDER=resend (never use in production).
# EMAIL_DELIVERY_MODE=log

# --- Resend hosted templates (server-only) ---
# Prefer these over LEAD_* aliases. Values are published template UUIDs or aliases.
# Never set NEXT_PUBLIC_ on any of these.
RESEND_API_KEY=
RESEND_FROM_EMAIL="Koppie Systems <hello@example.co.za>"
RESEND_INTERNAL_TO_EMAIL=hello@example.co.za
RESEND_REPLY_TO_EMAIL=hello@example.co.za
RESEND_TEMPLATE_CONTACT_INTERNAL=
RESEND_TEMPLATE_CONTACT_CONFIRMATION=
RESEND_TEMPLATE_PROPOSAL_INTERNAL=
RESEND_TEMPLATE_PROPOSAL_CONFIRMATION=

# --- SEO Audit products (two-tier) ---
# Basic / Priority Fix Pack
SEO_AUDIT_BASIC_ACTIVE=true
SEO_AUDIT_BASIC_PRICE_ZAR=2950
NEXT_PUBLIC_SEO_AUDIT_BASIC_CHECKOUT_URL=
# Legacy aliases still honoured for the basic pack:
# SEO_AUDIT_PRODUCT_ACTIVE=true
# SEO_AUDIT_PRICE_ZAR=2950
# NEXT_PUBLIC_SEO_AUDIT_CHECKOUT_URL=

# Advanced Audit & Implementation Roadmap
SEO_AUDIT_ADVANCED_ACTIVE=true
SEO_AUDIT_ADVANCED_PRICE_ZAR=8500
NEXT_PUBLIC_SEO_AUDIT_ADVANCED_CHECKOUT_URL=

# Shared payment webhook (server-only) + optional order mailbox
SEO_AUDIT_PAYMENT_WEBHOOK_SECRET=
SEO_AUDIT_ORDER_EMAIL=
